# =========================================================================
# FasonRAT MDM - Docker Environment Variables Example
# Copy this file to .env in the same directory:
#   cp .env.example .env
# Then replace YOUR_SERVER_PUBLIC_IP with your actual server public IP.
# =========================================================================

# Node Environment
NODE_ENV=production
LOG_LEVEL=info

# JWT Authentication Secret
JWT_SECRET=super_secret_jwt_key_please_change_me_12345

# TURN Server Configuration (For remote WebRTC/Screen Control across different networks)
# If coturn is deployed on the same server, set this to your server's public IP.
STUN_URL=stun:stun.l.google.com:19302
TURN_HOST=YOUR_SERVER_PUBLIC_IP
TURN_PORT=3478
# Generate a unique value, for example: openssl rand -hex 32
TURN_SECRET=CHANGE_ME_TO_AT_LEAST_32_RANDOM_CHARACTERS
TURN_EXTERNAL_IP=YOUR_SERVER_PUBLIC_IP
TURN_REALM=fason.example
# Only enable after Coturn has a trusted certificate and private key configured.
# TURN_TLS_PORT=5349
