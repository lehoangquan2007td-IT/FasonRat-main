# =========================================================================
# FasonRAT MDM - Root Environment Variables Example
# Docker Compose: copy this file to docker/.env. CLI deployments must export
# the same variables in the backend process environment.
# =========================================================================

# Node Environment
NODE_ENV=production
LOG_LEVEL=info

# JWT Authentication Secret
JWT_SECRET=super_secret_jwt_key_please_change_me_12345

# TURN Server Configuration (For remote WebRTC/Screen Control across different networks)
STUN_URL=stun:stun.l.google.com:19302
TURN_HOST=YOUR_SERVER_PUBLIC_IP_OR_DNS
TURN_PORT=3478
# Public relay IP advertised by Coturn. If the host is behind 1:1 NAT, use
# PUBLIC_IP/PRIVATE_IP (for example 203.0.113.10/10.0.0.5).
TURN_EXTERNAL_IP=YOUR_SERVER_PUBLIC_IP
TURN_REALM=fason.example
# Must be a long random value and must match the Coturn static auth secret.
TURN_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
# Optional when Coturn is configured with a certificate.
# TURN_TLS_PORT=5349
